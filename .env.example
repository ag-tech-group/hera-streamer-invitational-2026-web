# Backend API base URL (defaults to /api when unset)
VITE_API_URL=http://localhost:8000

# Auth endpoints (shared criticalbit auth). Both default to the deployed
# *.criticalbit.gg services when unset; override to point at local auth
# instances during auth development (e.g. if local sign-in needs a local
# auth API rather than the production one).
# VITE_AUTH_URL=https://auth.criticalbit.gg
# VITE_AUTH_API_URL=https://auth-api.criticalbit.gg

# Tournament config this build serves (see src/config/tournaments).
# Defaults to hera-streamer-invitational-2026 when unset.
VITE_TOURNAMENT_SLUG=hera-streamer-invitational-2026

# Client log level: trace | debug | info | warn | error | silent
VITE_LOG_LEVEL=info

# Sentry error tracking. Setting VITE_SENTRY_DSN enables runtime capture;
# unset = SDK never initialises (zero events from dev).
# VITE_SENTRY_DSN=https://<key>@<org>.ingest.us.sentry.io/<project>

# Sentry sampling rates (each 0 to 1). Defaults live in src/lib/sentry.ts:
# traces 0.05, replays-on-error 0.10, replays-session 0. Logs are on by default
# and forwarded from src/lib/logger.ts at the app log level (warn+ in prod).
# Set any of these to override the default — 0 to silence a category, higher to
# debug. Pair traces/replays with a per-category spend cap in the Sentry
# dashboard so a spike can't run away with quota.
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.05
# VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
# VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=0.1

# PostHog product analytics. Setting VITE_POSTHOG_KEY enables event capture;
# unset = SDK never initialises (zero events from dev).
# VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxx
#
# VITE_POSTHOG_HOST sets the ingestion host (defaults to PostHog US cloud,
# https://us.i.posthog.com). In production point it at the first-party reverse
# proxy so ad / privacy blockers don't drop events — the `/relay/*` rewrites in
# netlify.toml forward it to PostHog server-side:
#   VITE_POSTHOG_HOST=https://aoe2.criticalbit.gg/relay
# Leave unset (or set to us.i.posthog.com) for local dev / direct ingestion.
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# Feature flags: any VITE_FEATURE_<name>=true exposes flag `<name>` at runtime
# VITE_FEATURE_EXAMPLE=true
